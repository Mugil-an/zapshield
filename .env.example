# Server
NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5433
DB_NAME=zapshield
DB_USER=zapshield_user
DB_PASSWORD=changeme

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=admin-super-secret-jwt-key-minimum-32-chars
ADMIN_JWT_EXPIRES_IN=8h

# Razorpay (TEST MODE ONLY)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Open-Meteo (no API key needed — free tier)
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# ML Service
ML_SERVICE_URL=http://localhost:5001

# OTP (mocked in dev)
OTP_EXPIRY_SECONDS=300
DEV_MOCK_OTP=123456

# Trigger Engine
TRIGGER_POLL_INTERVAL_MINUTES=15
RAIN_THRESHOLD_MM=4.0
HEAT_THRESHOLD_CELSIUS=40.0
AQI_THRESHOLD=300
DISPATCH_FRAUD_THRESHOLD_PCT=40.0
